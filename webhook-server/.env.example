# Copy this file to .env and fill in values before running locally.
# In Railway, set these as environment variables in the project dashboard.

# Server
PORT=3000

# Where to send notifications
MICHAEL_EMAIL=michael@lehr-law.com

# SMTP (Outlook / Office 365)
# Use an App Password, not your main password.
# For Office 365: Settings > Mail > View all Outlook settings > Mail > Sync email > App passwords
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=michael@lehr-law.com
SMTP_PASS=your-app-password-here
SMTP_FROM=michael@lehr-law.com

# Calendly webhook signing key
# Calendly dashboard → Integrations → Webhooks → your webhook → Signing key
CALENDLY_WEBHOOK_SIGNING_KEY=

# Microsoft Graph — SharePoint Client Pipeline sync
# Azure AD app registration using the client-credentials flow, Sites.Selected
# permission, granted write access to the "Lehr Law Practice" site only.
# See README.md "SharePoint Client Pipeline sync" section for setup steps.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_LIST_ID=

# Tally form ID (the alphanumeric ID from the Tally form URL)
TALLY_FORM_ID=ob17lb

# Optional: forward a structured JSON payload to a second destination.
# Examples:
#   Power Automate HTTP trigger URL
#   Relay.app webhook URL
#   Zapier catch-hook URL
# Leave blank to disable forwarding.
DOWNSTREAM_URL=