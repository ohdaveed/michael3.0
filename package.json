{
  "name": "michael2.0",
  "version": "1.0.0",
  "private": true,
  "description": "Static website for Michael Lehr Law",
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "format": "prettier --write \"*.{html,css,js,json,md}\" \"docs/**/*.{md,json}\" \"public/**/*.{html,css,js,json}\"",
    "format:check": "prettier --check \"*.{html,css,js,json,md}\" \"docs/**/*.{md,json}\" \"public/**/*.{html,css,js,json}\"",
    "html:check": "htmlhint \"public/*.html\" && npm run html:check:partials",
    "html:check:partials": "htmlhint --rules tagname-lowercase,attr-value-double-quotes,tag-pair,spec-char-escape,id-unique,src-not-empty,attr-no-duplication \"public/partials/*.html\"",
    "links:check": "linkinator http://localhost:5173 --recurse --skip \"mailto:*\"",
    "a11y:check": "pa11y http://localhost:5173",
    "lighthouse": "lighthouse http://localhost:5173 --output=html --output-path=./lighthouse-report.html --chrome-flags=\"--headless=new --no-sandbox\"",
    "browser:check": "agent-browser open http://localhost:5173 && agent-browser wait --load networkidle && agent-browser snapshot -i",
    "test:e2e": "playwright test",
    "check": "npm run format:check && npm run html:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "agent-browser": "^0.26.0",
    "htmlhint": "^1.9.2",
    "husky": "^9.1.7",
    "lighthouse": "^12.6.1",
    "linkinator": "^7.6.1",
    "lint-staged": "^17.0.8",
    "pa11y": "^9.1.1",
    "prettier": "^3.8.3",
    "sharp": "^0.35.3",
    "svgo": "^4.0.2",
    "vite": "^8.1.4",
    "vite-plugin-image-optimizer": "^2.0.3"
  },
  "dependencies": {
    "driver.js": "^1.6.0",
    "fuse.js": "^7.4.2"
  },
  "lint-staged": {
    "**/*.{html,css,js,json,md}": "prettier --write",
    "public/*.html": "htmlhint",
    "public/partials/*.html": "htmlhint --rules tagname-lowercase,attr-value-double-quotes,tag-pair,spec-char-escape,id-unique,src-not-empty,attr-no-duplication"
  },
  "packageManager": "npm@12.0.1"
}
