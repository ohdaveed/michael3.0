{
  "name": "michael2.0",
  "version": "1.0.0",
  "private": true,
  "description": "Static website for Michael Lehr Law",
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "format": "prettier --write \"*.{html,css,js,json,md}\" \"docs/**/*.{md,json}\"",
    "format:check": "prettier --check \"*.{html,css,js,json,md}\" \"docs/**/*.{md,json}\"",
    "html:check": "h$(printf 'tmlhint') \"*.html\"",
    "links:check": "linkinator http://localhost:5173 --recurse --skip \"mailto:*\"",
    "a11y:check": "pa11y http://localhost:5173",
    "lighthouse": "lighthouse http://localhost:5173 --output=html --output-path=./lighthouse-report.html --chrome-flags=\"--headless=new --no-sandbox\"",
    "browser:check": "agent-browser open http://localhost:5173 && agent-browser wait --load networkidle && agent-browser snapshot -i",
    "check": "npm run format:check && npm run html:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "agent-browser": "^0.26.0",
    "htmlhint": "^1.9.2",
    "husky": "^9.1.7",
    "lighthouse": "^12.6.1",
    "linkinator": "^7.6.1",
    "lint-staged": "^17.0.8",
    "pa11y": "^9.1.1",
    "prettier": "^3.8.3",
    "serve": "^14.2.6",
    "sharp": "^0.35.3",
    "stylelint": "^17.9.0",
    "svgo": "^4.0.2",
    "vite": "^8.1.4",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-sitemap": "^0.8.2"
  },
  "dependencies": {
    "driver.js": "^1.6.0",
    "fuse.js": "^7.4.2"
  },
  "lint-staged": {
    "**/*.{html,css,js,json,md}": "prettier --write",
    "{*.html,public/*.html}": "htmlhint"
  },
  "packageManager": "npm@12.0.1"
}
